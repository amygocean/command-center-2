# ------------------------------------------------------------------
#  Ocean Basket Academy Command Center — environment variables
#  Copy these into your host's "Environment Variables" settings
#  (Vercel: Project → Settings → Environment Variables).
#  NEVER commit real values to git.
# ------------------------------------------------------------------

# From your Asana OAuth app (Asana → Settings → Apps → Developer apps)
ASANA_CLIENT_ID=your-asana-client-id
ASANA_CLIENT_SECRET=your-asana-client-secret

# The exact deployed URL of this app (no trailing slash), e.g. https://academy-command-center.vercel.app
APP_URL=https://your-app-url

# Your Asana workspace GID (Ocean Basket = 14491666778313)
ASANA_WORKSPACE=14491666778313

# Anthropic API key for the AI features (content ideas + chat summaries).
# Get one at console.anthropic.com. Leave blank to disable AI features.
ANTHROPIC_API_KEY=your-anthropic-key

# A long random string used to sign the login cookie. Generate one, keep it secret.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Morning digest email (all optional — skip these and the cron just no-ops) ---
# Asana personal access token so the scheduled digest can read the boards
ASANA_PAT=
# resend.com API key for sending the email (free tier is plenty)
RESEND_API_KEY=
# Comma-separated recipients, e.g. amy@x.com,caitlin@x.com,jess@x.com
DIGEST_TO=
# Optional verified sender, e.g. "Command Center <center@yourdomain.com>"
DIGEST_FROM=
# Optional: protects /api/digest so only Vercel's cron can call it
CRON_SECRET=
